# shellcheck shell=sh disable=SC2034
DATABASE_URL="postgresql://veganmealplanner:veganmealplanner@localhost:5432/veganmealplanner"
# Optional. Prisma Migrate shadow DB URL; see prisma.config.ts. Set when DATABASE_URL is nonstandard
# (e.g. socket-only) so the derived shadow URL would be incorrect.
# SHADOW_DATABASE_URL=

# API (see contracts/openapi.yaml)
# PORT=3000
# AUTH_MODE=development
# When AUTH_MODE=development, send X-Dev-User-Id: <user-uuid> instead of JWT.
# When AUTH_MODE=production (default), use Authorization: Bearer <jwt> with sub claim.
#
# JWT (required when AUTH_MODE is not development; empty/unset is invalid for bearer JWT in that mode)
# JWT_SECRET — minimum 32 UTF-8 bytes, cryptographically random (HS256). Example:
#   openssl rand -base64 48
# JWT_EXPIRES_IN=3600   # access token TTL in seconds
#
# dev-seed (`bun run dev-seed`): optional override for the seeded dev user password (min 10 chars).
# Default password is documented in README.md if unset.
# DEV_SEED_PASSWORD=
#
# Argon2id hashing costs (memory/time/parallelism) are defined in code as ARGON2_PASSWORD_OPTIONS
# in src/api/password.ts — not configurable via environment variables.
