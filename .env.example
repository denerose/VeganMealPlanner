# shellcheck shell=sh disable=SC2034
DATABASE_URL="postgresql://veganmealplanner:veganmealplanner@localhost:5432/veganmealplanner"

# API (see contracts/openapi.yaml)
# PORT=3000
# AUTH_MODE=development
# When AUTH_MODE=development, send X-Dev-User-Id: <user-uuid> instead of JWT.
# When AUTH_MODE=production (default), use Authorization: Bearer <jwt> with sub claim.
#
# JWT (required when AUTH_MODE is not development)
# JWT_SECRET=   # long random string
# JWT_EXPIRES_IN=3600   # access token TTL in seconds
#
# dev-seed (`bun run dev-seed`): optional override for the seeded dev user password (min 10 chars).
# Default password is documented in README.md if unset.
# DEV_SEED_PASSWORD=
